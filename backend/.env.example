# ==============================================
# Transport ERP - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to git — it is in .gitignore
# API keys use placeholder values (YOUR_*_HERE).
# The app returns mock data when placeholders are detected.
# Replace with real keys to switch to live API calls.

# Application
APP_NAME=Transport ERP
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 64 chars in production
SECRET_KEY=YOUR_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# PostgreSQL
# Production: use SSL → append ?ssl=require to host
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=transport_erp
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
POSTGRES_DB=transport_erp

# MongoDB (add :password@ if auth is enabled)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=transport_erp_logs

# Redis (set password in production: redis://:PASSWORD@localhost:6379/0)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# CORS — production: restrict to your real domains only, never "*"
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Government APIs
VAHAN_API_KEY=YOUR_VAHAN_API_KEY_HERE
SARATHI_API_KEY=YOUR_SARATHI_API_KEY_HERE
ECHALLAN_API_KEY=YOUR_ECHALLAN_API_KEY_HERE

# GST & E-way Bill
EWAY_BILL_USERNAME=YOUR_EWAYB_USERNAME_HERE
EWAY_BILL_PASSWORD=YOUR_EWAYB_PASSWORD_HERE
EWAY_BILL_GSTIN=YOUR_COMPANY_GSTIN_HERE
GST_VERIFY_API_KEY=YOUR_GST_VERIFY_KEY_HERE

# Google APIs
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase
FIREBASE_CREDENTIALS_PATH=YOUR_FIREBASE_CREDENTIALS_PATH_HERE

# AWS / S3
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME_HERE
AWS_REGION=ap-south-1

# Communication — MSG91 (OTP widget)
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY_HERE
MSG91_WIDGET_ID=YOUR_MSG91_WIDGET_ID_HERE
MSG91_API_KEY=YOUR_MSG91_API_KEY_HERE
MSG91_SENDER_ID=KAVYAT
WHATSAPP_API_KEY=YOUR_GUPSHUP_API_KEY_HERE
WHATSAPP_SOURCE_NUMBER=YOUR_WHATSAPP_NUMBER_HERE

# Communication — Brevo (email/SMS)
BREVO_API_KEY=YOUR_BREVO_API_KEY_HERE

# Email SMTP (Brevo SMTP relay)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=YOUR_BREVO_SMTP_USER_HERE
SMTP_PASSWORD=YOUR_BREVO_SMTP_PASSWORD_HERE

# Finance — Razorpay (client payment gateway)
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

# Finance — Razorpay X (driver payout)
RAZORPAY_X_KEY_ID=YOUR_RAZORPAY_X_KEY_ID_HERE
RAZORPAY_X_KEY_SECRET=YOUR_RAZORPAY_X_KEY_SECRET_HERE
RAZORPAY_X_ACCOUNT_NUMBER=YOUR_RAZORPAY_X_ACCOUNT_HERE

# AI / OCR
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
HF_API_KEY=YOUR_HF_API_KEY_HERE
OCR_SPACE_API_KEY=YOUR_OCR_SPACE_API_KEY_HERE

# Feature Flags
USE_MOCK_VAHAN=true
USE_MOCK_MAPS=true
USE_MOCK_PAYMENTS=true
USE_MOCK_SMS=true
USE_MOCK_WHATSAPP=true
USE_MOCK_S3=true
USE_MOCK_FCM=true

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
LOG_LEVEL=INFO

# ─── IFIAS — Invoice Automation ───────────────────────────────────────────────
# Outlook IMAP (use an App Password if MFA is enabled)
IMAP_EMAIL=yogendiran.c@kavyatransports.com
IMAP_PASSWORD=your_outlook_app_password_here
IMAP_SERVER=imap-mail.outlook.com
IMAP_PORT=993
IMAP_SEARCH_FOLDERS=INBOX,Sent Items

# OneDrive billing Excel watch path (where Yogendiran saves the billing file)
ONEDRIVE_WATCH_PATH=C:/Users/YogeC/OneDrive - Kavya Transports/Kavya transports
ONEDRIVE_WATCH_PATTERN=Invoice Reference

# Confidence thresholds (0–1)
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_REVIEW_THRESHOLD=0.60

# AI Document Extraction (API-first)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Hugging Face Inference API (Donut DocVQA) — recommended
HF_API_KEY=YOUR_HF_API_KEY_HERE
HF_MODEL_ID=naver-clova-ix/donut-base-finetuned-docvqa

# Local OCR engines are disabled by default.
# Keep both false to force API-based extraction.
USE_LOCAL_DONUT=false
USE_LOCAL_TESSERACT=false
