# ==============================================
# Transport ERP - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# API keys use placeholder values (YOUR_*_HERE).
# The app returns mock data when placeholders are detected.
# Replace with real keys to switch to live API calls.

# Application
APP_NAME=Transport ERP
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Security — CHANGE THIS in production!
SECRET_KEY=change-this-to-a-super-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=transport_erp
POSTGRES_PASSWORD=password
POSTGRES_DB=kavya_transports_db

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=transport_erp_logs

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Government APIs
VAHAN_API_KEY=YOUR_VAHAN_API_KEY_HERE
SARATHI_API_KEY=YOUR_SARATHI_API_KEY_HERE
ECHALLAN_API_KEY=YOUR_ECHALLAN_API_KEY_HERE

# GST & E-way Bill
EWAY_BILL_USERNAME=YOUR_EWAYB_USERNAME_HERE
EWAY_BILL_PASSWORD=YOUR_EWAYB_PASSWORD_HERE
EWAY_BILL_GSTIN=YOUR_COMPANY_GSTIN_HERE
GST_VERIFY_API_KEY=YOUR_GST_VERIFY_KEY_HERE

# Google APIs
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase
FIREBASE_CREDENTIALS_PATH=YOUR_FIREBASE_CREDENTIALS_PATH_HERE

# AWS / S3
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME_HERE

# Communication
MSG91_API_KEY=YOUR_MSG91_API_KEY_HERE
WHATSAPP_API_KEY=YOUR_GUPSHUP_API_KEY_HERE

# Finance
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE

# Feature Flags
USE_MOCK_VAHAN=True
USE_MOCK_MAPS=True
USE_MOCK_PAYMENTS=True
USE_MOCK_SMS=True
USE_MOCK_WHATSAPP=True
USE_MOCK_S3=True
USE_MOCK_FCM=True

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
LOG_LEVEL=INFO
