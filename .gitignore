# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/
.venv/
.env
*.env

# Node
node_modules/
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Migrations (keep folder, ignore auto-generated)
backend/migrations/versions/

# Uploads
backend/uploads/

# Playwright artifacts (generated test output — never commit these)
frontend/dist/
frontend/test-results/
frontend/playwright-report/
frontend/tests/playwright-report/
frontend/playwright-report/
frontend/tests/playwright-report/
frontend/test-artifacts/
frontend/.playwright/
**/test-results/
**/playwright-report/
**/test-artifacts/

# Playwright auth state — contains session tokens (SECURITY RISK if committed)
**/tests/setup/.auth/

# Gradle — Android build caches (machine-specific binaries, will crash other devs)
**/.gradle/
**/build/
gradle-cache/
kavya_app/android/.gradle/
kavya_app/android/build/
kavya_app/android/app/build/

# Flutter tool-generated files (contain absolute paths from dev machine)
kavya_app/.dart_tool/
**/.dart_tool/
kavya_app/.flutter-plugins
kavya_app/.flutter-plugins-dependencies

# General generated / debug artifacts
*.webm
*.zip
**/test-results/**/*.png
# Debug/inspection screenshots from test scripts
frontend/inspect_*.png
frontend/ui_clickthrough_result.png
frontend/*_result.png

# Uploaded user files (binaries, not source code)
backend/uploads/documents/

# Flutter obfuscation symbol mapping — REQUIRED for stack-trace symbolication
# but MUST NEVER be committed (contains the de-obfuscation map for the APK).
kavya_app/build/debug-info/
**/build/debug-info/
*.symbols

# ── Test & coverage artifacts ─────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
backend/htmlcov/
backend/.coverage
backend/.pytest_cache/
.pytest_cache/
coverage.xml

# ── Load / smoke test reports ─────────────────────────────────────────────────
load_report.html
locust_report.html
locust_stats.csv
locust_failures.csv
locust_report*

# ── Celery runtime files ──────────────────────────────────────────────────────
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid
backend/celerybeat-schedule
backend/celerybeat-schedule.db

# ── Cleanup script output ─────────────────────────────────────────────────────
cleanup_log.txt
kavya_cleanup_report.txt

# ── Frontend build cache ──────────────────────────────────────────────────────
frontend/.vite/
frontend/node_modules/.cache/

# ── Diagnostic one-off scripts (prefixed with _) ─────────────────────────────
backend/_*.py

# ── Backup / temp files ───────────────────────────────────────────────────────
*.bak
*.orig
*_old.*

# ── Production env (contains real secrets — store on server only) ─────────────
backend/.env.production
frontend/.env.production.local

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pyc
*.pyo
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
